<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>自動ふりがな付与ツール</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/kuromoji@0.1.2/build/kuromoji.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;600;700&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --primary: #1e40af;
    --primary-light: #3b82f6;
    --primary-dark: #1e3a8a;
    --accent: #0ea5e9;
    --surface: #f8faff;
    --border: #dbeafe;
    --text: #1e293b;
    --muted: #64748b;
    --success: #059669;
    --warning: #d97706;
  }

  * { box-sizing: border-box; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 50%, #f8faff 100%);
    min-height: 100vh;
    color: var(--text);
  }

  /* ローディング画面 */
  #loading-screen {
    position: fixed;
    inset: 0;
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #0ea5e9 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  #loading-screen.hidden {
    opacity: 0;
    visibility: hidden;
  }

  .spinner {
    width: 56px;
    height: 56px;
    border: 4px solid rgba(255,255,255,0.2);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin-top: 1.5rem;
    letter-spacing: 0.05em;
  }

  .loading-sub {
    color: rgba(255,255,255,0.75);
    margin-top: 0.5rem;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
  }

  /* メインレイアウト */
  #app {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  #app.visible { opacity: 1; }

  /* ヘッダー */
  .app-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #2563eb 100%);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: 0 4px 20px rgba(30,64,175,0.3);
  }

  .app-header .logo {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
  }

  .app-header .badge {
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.06em;
  }

  /* パネル */
  .panel {
    background: #fff;
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 16px rgba(30,64,175,0.06), 0 1px 4px rgba(30,64,175,0.04);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .panel-header {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .panel-header .panel-title {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--primary-dark);
    letter-spacing: 0.04em;
  }

  .panel-icon {
    width: 22px;
    height: 22px;
    background: var(--primary);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .panel-icon svg { color: #fff; }

  .panel-body { padding: 1rem; flex: 1; display: flex; flex-direction: column; }

  /* テキストエリア */
  .styled-textarea {
    width: 100%;
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--text);
    background: #fafcff;
    resize: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  .styled-textarea:focus {
    border-color: var(--primary-light);
    box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    background: #fff;
  }

  /* 出力エリア */
  #output-area {
    min-height: 200px;
    padding: 0.85rem 1rem;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.92rem;
    line-height: 2.4;
    color: var(--text);
    background: #fafcff;
    outline: none;
    flex: 1;
    overflow-y: auto;
    cursor: text;
    transition: border-color 0.2s;
  }

  #output-area:focus {
    border-color: var(--primary-light);
    box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    background: #fff;
  }

  #output-area ruby { ruby-align: center; }
  #output-area rt {
    font-size: 0.55em;
    color: var(--primary);
    font-family: 'Noto Sans JP', sans-serif;
    letter-spacing: 0.03em;
  }

  #output-area:empty::before {
    content: 'ふりがなを付けると、ここに結果が表示されます。直接編集も可能です。';
    color: #94a3b8;
    font-style: italic;
    font-size: 0.88rem;
  }

  /* ボタン */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.55rem 1.1rem;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: 'Noto Sans JP', sans-serif;
    letter-spacing: 0.03em;
    cursor: pointer;
    border: none;
    transition: all 0.18s ease;
    white-space: nowrap;
    outline: none;
  }

  .btn:active { transform: scale(0.97); }

  .btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: #fff;
    box-shadow: 0 2px 8px rgba(30,64,175,0.3);
  }
  .btn-primary:hover {
    background: linear-gradient(135deg, var(--primary-dark), var(--primary));
    box-shadow: 0 4px 14px rgba(30,64,175,0.4);
  }

  .btn-accent {
    background: linear-gradient(135deg, #0284c7, #0ea5e9);
    color: #fff;
    box-shadow: 0 2px 8px rgba(14,165,233,0.3);
  }
  .btn-accent:hover {
    background: linear-gradient(135deg, #0369a1, #0284c7);
    box-shadow: 0 4px 14px rgba(14,165,233,0.4);
  }

  .btn-success {
    background: linear-gradient(135deg, #059669, #10b981);
    color: #fff;
    box-shadow: 0 2px 8px rgba(5,150,105,0.3);
  }
  .btn-success:hover {
    background: linear-gradient(135deg, #047857, #059669);
    box-shadow: 0 4px 14px rgba(5,150,105,0.4);
  }

  .btn-outline {
    background: #fff;
    color: var(--primary);
    border: 1.5px solid var(--primary-light);
    box-shadow: 0 1px 4px rgba(30,64,175,0.08);
  }
  .btn-outline:hover {
    background: #eff6ff;
    box-shadow: 0 2px 8px rgba(30,64,175,0.15);
  }

  .btn-sm { padding: 0.35rem 0.75rem; font-size: 0.75rem; }

  /* ファイルボタン */
  .file-btn-wrap {
    position: relative;
    display: inline-flex;
  }
  .file-btn-wrap input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
  }

  /* トースト */
  #toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: #1e293b;
    color: #fff;
    padding: 0.7rem 1.4rem;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
    z-index: 9000;
    white-space: nowrap;
  }
  #toast.show { transform: translateX(-50%) translateY(0); }
  #toast.success { background: #059669; }
  #toast.error { background: #dc2626; }

  /* カスタム辞書パネル */
  .dict-panel {
    background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
    border: 1.5px solid #a7f3d0;
    border-radius: 12px;
    overflow: hidden;
  }

  .dict-header {
    background: linear-gradient(135deg, #d1fae5, #a7f3d0);
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #a7f3d0;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .dict-title {
    font-weight: 700;
    font-size: 0.85rem;
    color: #065f46;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* 仕切り線 */
  .divider {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border), transparent);
    margin: 0.75rem 0;
  }

  /* アニメーション */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-in { animation: fadeInUp 0.4s ease both; }
  .fade-in-1 { animation-delay: 0.05s; }
  .fade-in-2 { animation-delay: 0.1s; }
  .fade-in-3 { animation-delay: 0.15s; }

  /* 処理中オーバーレイ */
  #processing-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(4px);
    z-index: 8000;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  #processing-overlay.active { display: flex; }

  .processing-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem 3rem;
    box-shadow: 0 20px 60px rgba(30,64,175,0.15);
    text-align: center;
    border: 1px solid var(--border);
  }

  /* スクロールバー */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 3px; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

  /* モバイル対応 */
  @media (max-width: 768px) {
    .main-grid { flex-direction: column; }
    .app-header .logo { font-size: 1.1rem; }
  }
</style>
</head>
<body>

<!-- ローディング画面 -->
<div id="loading-screen">
  <div class="spinner"></div>
  <div class="loading-title">ふりがな付与ツール</div>
  <div class="loading-sub">辞書データを読み込んでいます…</div>
  <div style="margin-top:1.5rem;color:rgba(255,255,255,0.5);font-size:0.8rem;">
    kuromoji.js · 形態素解析エンジン
  </div>
</div>

<!-- 処理中オーバーレイ -->
<div id="processing-overlay">
  <div class="processing-card">
    <div class="spinner" style="margin:0 auto;border-top-color:var(--primary);border-color:rgba(30,64,175,0.15);"></div>
    <div style="margin-top:1rem;font-weight:600;color:var(--primary-dark);font-size:0.95rem;">ふりがなを付与しています…</div>
    <div style="color:var(--muted);font-size:0.82rem;margin-top:0.3rem;">しばらくお待ちください</div>
  </div>
</div>

<!-- トースト -->
<div id="toast"></div>

<!-- メインアプリ -->
<div id="app">
  <!-- ヘッダー -->
  <header class="app-header">
    <div style="display:flex;align-items:center;gap:0.75rem;flex:1">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="28" height="28" rx="8" fill="rgba(255,255,255,0.15)"/>
        <text x="5" y="21" font-size="16" fill="white" font-family="serif">文</text>
        <text x="15" y="13" font-size="9" fill="rgba(255,255,255,0.8)" font-family="sans-serif">ふり</text>
      </svg>
      <div class="logo">自動ふりがな付与ツール</div>
      <span class="badge">kuromoji.js</span>
    </div>
  </header>

  <!-- メインコンテンツ -->
  <main style="padding:1.25rem;max-width:1600px;margin:0 auto;">

    <!-- ふりがなボタン（中央） -->
    <div class="fade-in" style="display:flex;justify-content:center;margin-bottom:1rem;">
      <button class="btn btn-primary" onclick="processText()" style="padding:0.7rem 2.5rem;font-size:1rem;border-radius:12px;box-shadow:0 4px 20px rgba(30,64,175,0.35);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        ふりがなを付ける
      </button>
    </div>

    <!-- 2カラムグリッド -->
    <div class="main-grid" style="display:flex;gap:1.25rem;align-items:stretch;">

      <!-- === 左パネル：入力 === -->
      <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:1rem;">

        <!-- 入力テキスト -->
        <div class="panel fade-in fade-in-1" style="flex:1;">
          <div class="panel-header">
            <div class="panel-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <span class="panel-title">入力テキスト</span>
            <div style="margin-left:auto;display:flex;gap:0.4rem;flex-wrap:wrap;">
              <div class="file-btn-wrap">
                <button class="btn btn-outline btn-sm">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  ファイル読込
                </button>
                <input type="file" accept=".txt,.docx" onchange="loadInputFile(event)">
              </div>
              <button class="btn btn-outline btn-sm" onclick="clearInput()">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                クリア
              </button>
            </div>
          </div>
          <div class="panel-body">
            <textarea id="input-text" class="styled-textarea" style="min-height:300px;" placeholder="ここにテキストを入力または貼り付けてください。
.txt / .docx ファイルの読み込みも可能です。

例：
日本語のテキストを入力すると、漢字に自動でふりがなが付きます。
食べる、読む、書くなどの送り仮名も適切に処理されます。"></textarea>
            <div style="margin-top:0.5rem;display:flex;align-items:center;gap:0.4rem;">
              <div id="char-count" style="font-size:0.75rem;color:var(--muted);margin-left:auto;">0 文字</div>
            </div>
          </div>
        </div>

        <!-- カスタム辞書 -->
        <div class="dict-panel fade-in fade-in-2">
          <div class="dict-header">
            <div class="dict-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#065f46" stroke-width="2.5"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
              カスタム辞書
              <span style="font-weight:400;color:#059669;font-size:0.78rem;">（自動解析より優先）</span>
            </div>
            <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
              <div class="file-btn-wrap">
                <button class="btn btn-sm" style="background:#d1fae5;color:#065f46;border:1.5px solid #6ee7b7;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  辞書読込
                </button>
                <input type="file" accept=".txt,.csv,.docx" onchange="loadDictFile(event)">
              </div>
              <button class="btn btn-sm" style="background:#d1fae5;color:#065f46;border:1.5px solid #6ee7b7;" onclick="clearDict()">クリア</button>
            </div>
          </div>
          <div style="padding:0.75rem;">
            <div style="font-size:0.75rem;color:#059669;margin-bottom:0.4rem;padding:0.4rem 0.6rem;background:rgba(209,250,229,0.5);border-radius:6px;border-left:3px solid #34d399;">
              形式：<code style="background:rgba(5,150,105,0.1);padding:0.1rem 0.3rem;border-radius:3px;font-size:0.78rem;">単語,ふりがな</code> または <code style="background:rgba(5,150,105,0.1);padding:0.1rem 0.3rem;border-radius:3px;font-size:0.78rem;">単語 ふりがな</code>　（1行1エントリ）
            </div>
            <textarea id="dict-text" class="styled-textarea" style="min-height:110px;border-color:#a7f3d0;background:#f0fdf4;font-size:0.82rem;" placeholder="例：
人工知能,じんこうちのう
機械学習 きかいがくしゅう
自然言語処理,しぜんげんごしょり
kuromoji,くろもじ"></textarea>
          </div>
        </div>

      </div><!-- / 左パネル -->

      <!-- === 右パネル：出力 === -->
      <div style="flex:1;min-width:0;">
        <div class="panel fade-in fade-in-3" style="height:100%;">
          <div class="panel-header">
            <div class="panel-icon" style="background:var(--accent);">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            </div>
            <span class="panel-title">出力結果</span>
            <span style="font-size:0.72rem;color:var(--muted);margin-left:0.3rem;">直接編集可能</span>
            <div style="margin-left:auto;display:flex;gap:0.4rem;flex-wrap:wrap;">
              <button class="btn btn-outline btn-sm" onclick="copyOutput()">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                コピー
              </button>
              <button class="btn btn-success btn-sm" onclick="saveAsWord()">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Wordで保存
              </button>
              <button class="btn btn-outline btn-sm" onclick="clearOutput()">クリア</button>
            </div>
          </div>
          <div class="panel-body">
            <div id="output-area" contenteditable="true" spellcheck="false"></div>
            <div style="margin-top:0.5rem;display:flex;gap:0.75rem;align-items:center;">
              <div style="display:flex;align-items:center;gap:0.3rem;font-size:0.72rem;color:var(--muted);">
                <span style="display:inline-block;width:8px;height:8px;background:var(--primary);border-radius:50%;"></span>
                <ruby style="font-size:0.9em;color:var(--primary-dark);">漢字<rt style="font-size:0.7em;color:var(--primary);">かんじ</rt></ruby>
                ← ルビ表示サンプル
              </div>
              <div id="ruby-count" style="margin-left:auto;font-size:0.75rem;color:var(--muted);"></div>
            </div>
          </div>
        </div>
      </div><!-- / 右パネル -->

    </div><!-- / グリッド -->

  </main>
</div>

<script>
// =========================================================
// グローバル変数
// =========================================================
let tokenizer = null;

// =========================================================
// kuromoji 初期化
// =========================================================
kuromoji.builder({ dicPath: "https://cdn.jsdelivr.net/npm/kuromoji@0.1.2/dict/" })
  .build((err, _tokenizer) => {
    const loading = document.getElementById('loading-screen');
    const app = document.getElementById('app');
    if (err) {
      loading.innerHTML = `
        <div style="color:#fca5a5;font-size:1rem;text-align:center;padding:2rem;">
          <div style="font-size:2rem;margin-bottom:1rem;">⚠️</div>
          辞書の読み込みに失敗しました<br>
          <small style="color:rgba(255,255,255,0.6);margin-top:0.5rem;display:block;">ネットワーク接続を確認してください</small>
        </div>`;
      return;
    }
    tokenizer = _tokenizer;
    loading.classList.add('hidden');
    app.classList.add('visible');
    initCharCount();
  });

// =========================================================
// 文字数カウント
// =========================================================
function initCharCount() {
  const ta = document.getElementById('input-text');
  const counter = document.getElementById('char-count');
  ta.addEventListener('input', () => {
    counter.textContent = ta.value.length.toLocaleString() + ' 文字';
  });
}

// =========================================================
// ファイル読み込み
// =========================================================
async function loadInputFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  try {
    const text = await readFileAsText(file);
    document.getElementById('input-text').value = text;
    document.getElementById('char-count').textContent = text.length.toLocaleString() + ' 文字';
    showToast('ファイルを読み込みました', 'success');
  } catch(e) {
    showToast('読み込みエラー: ' + e.message, 'error');
  }
  event.target.value = '';
}

async function loadDictFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  try {
    const text = await readFileAsText(file);
    const ta = document.getElementById('dict-text');
    ta.value = ta.value ? ta.value.trimEnd() + '\n' + text : text;
    showToast('辞書ファイルを追記しました', 'success');
  } catch(e) {
    showToast('読み込みエラー: ' + e.message, 'error');
  }
  event.target.value = '';
}

async function readFileAsText(file) {
  const ext = file.name.split('.').pop().toLowerCase();
  if (ext === 'docx') {
    const arrayBuffer = await file.arrayBuffer();
    const result = await mammoth.extractRawText({ arrayBuffer });
    return result.value;
  } else {
    // txt / csv
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = e => resolve(e.target.result);
      reader.onerror = () => reject(new Error('ファイルの読み込みに失敗しました'));
      reader.readAsText(file, 'UTF-8');
    });
  }
}

// =========================================================
// カスタム辞書パース
// =========================================================
function parseCustomDict(dictText) {
  const dict = [];
  if (!dictText.trim()) return dict;
  const lines = dictText.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;
    // カンマ区切り or スペース区切り
    let word, reading;
    if (trimmed.includes(',')) {
      [word, reading] = trimmed.split(',').map(s => s.trim());
    } else {
      const parts = trimmed.split(/\s+/);
      word = parts[0];
      reading = parts[1];
    }
    if (word && reading) {
      dict.push({ word, reading });
    }
  }
  // 長い単語から優先（長さ降順）
  dict.sort((a, b) => b.word.length - a.word.length);
  return dict;
}

// =========================================================
// カスタム辞書による置換
// プレースホルダー方式で既置換済みに再適用しない
// =========================================================
function applyCustomDict(text, dict) {
  if (!dict.length) return text;
  // プレースホルダーMap: key -> rubyHTML
  const placeholders = new Map();
  let idx = 0;

  for (const { word, reading } of dict) {
    const escapedWord = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp(escapedWord, 'g');
    text = text.replace(re, (match) => {
      const key = `\x01${idx++}\x01`;
      placeholders.set(key, `<ruby>${match}<rt>${reading}</rt></ruby>`);
      return key;
    });
  }

  // プレースホルダーを最終的なrubyタグに戻す
  for (const [key, val] of placeholders) {
    text = text.split(key).join(val);
  }
  return text;
}

// =========================================================
// 送り仮名処理
// 「食べる」→ 漢字部分「食」に「た」、仮名部分はそのまま
// =========================================================
function splitKanjiAndKana(surface, reading) {
  // surfaceに含まれる漢字と仮名を分離
  // 末尾の仮名（送り仮名）を検出
  const trailKanaMatch = surface.match(/^([\u4e00-\u9fff\u3400-\u4dbf々〆〇ヵヶ]+)([\u3040-\u309f\u30a0-\u30ff]+)$/);
  if (!trailKanaMatch) return null; // 送り仮名なし

  const kanjiPart = trailKanaMatch[1];
  const kanaPart = trailKanaMatch[2];

  // 読みの末尾からひらがな部分を取り除く
  // 送り仮名（カタカナ→ひらがな変換後）との比較
  const kanaHira = toHiragana(kanaPart);
  const readingHira = toHiragana(reading);

  if (readingHira.endsWith(kanaHira)) {
    const kanjiReading = readingHira.slice(0, readingHira.length - kanaHira.length);
    if (kanjiReading) {
      return { kanjiPart, kanaHira, kanjiReading };
    }
  }
  return null;
}

function toHiragana(str) {
  return str.replace(/[\u30a1-\u30f6]/g, ch =>
    String.fromCharCode(ch.charCodeAt(0) - 0x60)
  );
}

// =========================================================
// kuromoji解析 + ルビ付与
// プレースホルダーが含まれる部分はスキップ
// =========================================================
function applyKuromojiRuby(text) {
  // テキストをプレースホルダーと通常テキストに分割
  // プレースホルダー(\x01...\x01)と実テキストを区別
  // ここではすでにカスタム辞書適用済みのHTMLが混在しているので
  // <ruby>...</ruby>タグ部分をスキップし、残りに形態素解析を適用

  // テキストをHTMLタグ・プレーンテキストに分割
  const segments = [];
  const tagRe = /(<ruby[\s\S]*?<\/ruby>|<[^>]+>)/g;
  let lastIdx = 0;
  let match;
  while ((match = tagRe.exec(text)) !== null) {
    if (match.index > lastIdx) {
      segments.push({ type: 'text', content: text.slice(lastIdx, match.index) });
    }
    segments.push({ type: 'html', content: match[0] });
    lastIdx = tagRe.lastIndex;
  }
  if (lastIdx < text.length) {
    segments.push({ type: 'text', content: text.slice(lastIdx) });
  }

  // 各テキストセグメントに形態素解析を適用
  const result = segments.map(seg => {
    if (seg.type === 'html') return seg.content;
    return tokenizeAndRuby(seg.content);
  });

  return result.join('');
}

function tokenizeAndRuby(text) {
  if (!text.trim()) return text;
  // 改行を保持するため、改行で分割してそれぞれ処理
  const lines = text.split('\n');
  return lines.map(line => {
    if (!line.trim()) return line;
    return tokenizeLine(line);
  }).join('\n');
}

function tokenizeLine(line) {
  const tokens = tokenizer.tokenize(line);
  let result = '';

  for (const token of tokens) {
    const surface = token.surface_form;
    const reading = token.reading;

    // 読みがない、または読みが同じ（ひらがなのみ等）
    if (!reading) { result += surface; continue; }

    const readingHira = toHiragana(reading);
    const surfaceHira = toHiragana(surface);

    // 読みと表記が同じ → ルビ不要
    if (surfaceHira === readingHira) { result += surface; continue; }

    // 漢字を含むかチェック
    if (!hasKanji(surface)) { result += surface; continue; }

    // 送り仮名処理
    const split = splitKanjiAndKana(surface, readingHira);
    if (split) {
      result += `<ruby>${split.kanjiPart}<rt>${split.kanjiReading}</rt></ruby>${split.kanaHira}`;
    } else {
      // 全体にルビ
      result += `<ruby>${surface}<rt>${readingHira}</rt></ruby>`;
    }
  }
  return result;
}

function hasKanji(str) {
  return /[\u4e00-\u9fff\u3400-\u4dbf々〆〇]/.test(str);
}

// =========================================================
// メイン処理
// =========================================================
async function processText() {
  const inputText = document.getElementById('input-text').value;
  if (!inputText.trim()) {
    showToast('テキストを入力してください', 'error');
    return;
  }
  if (!tokenizer) {
    showToast('辞書の読み込みが完了していません', 'error');
    return;
  }

  const overlay = document.getElementById('processing-overlay');
  overlay.classList.add('active');

  // 非同期で少し待ってからUI更新（UIブロック防止）
  await new Promise(r => setTimeout(r, 30));

  try {
    const dictText = document.getElementById('dict-text').value;
    const customDict = parseCustomDict(dictText);

    // 段落ごとに処理（改行保持）
    let processed = inputText;

    // Step1: カスタム辞書適用
    processed = applyCustomDict(processed, customDict);

    // Step2: kuromoji解析＋ルビ付与
    processed = applyKuromojiRuby(processed);

    // Step3: 改行 → <br> に変換（HTMLとして出力）
    processed = processed.replace(/\n/g, '<br>');

    // 出力
    const outputArea = document.getElementById('output-area');
    outputArea.innerHTML = processed;

    // ルビカウント
    const rubyCount = (processed.match(/<ruby>/g) || []).length;
    document.getElementById('ruby-count').textContent = `ルビ ${rubyCount.toLocaleString()} 箇所`;

    showToast(`完了！ ${rubyCount} 箇所にふりがなを付与しました`, 'success');
  } catch(e) {
    showToast('処理中にエラーが発生しました: ' + e.message, 'error');
    console.error(e);
  } finally {
    overlay.classList.remove('active');
  }
}

// =========================================================
// コピー（リッチテキスト）
// =========================================================
async function copyOutput() {
  const outputArea = document.getElementById('output-area');
  if (!outputArea.innerHTML.trim()) {
    showToast('コピーする内容がありません', 'error');
    return;
  }

  try {
    // Clipboard API でリッチテキスト（HTML）コピー
    if (navigator.clipboard && window.ClipboardItem) {
      const htmlBlob = new Blob([outputArea.innerHTML], { type: 'text/html' });
      const textBlob = new Blob([outputArea.innerText], { type: 'text/plain' });
      await navigator.clipboard.write([
        new ClipboardItem({ 'text/html': htmlBlob, 'text/plain': textBlob })
      ]);
      showToast('リッチテキストをコピーしました（Wordに貼り付け可）', 'success');
      return;
    }
  } catch(e) { /* fallback */ }

  // フォールバック: execCommand
  try {
    const range = document.createRange();
    range.selectNodeContents(outputArea);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
    document.execCommand('copy');
    sel.removeAllRanges();
    showToast('リッチテキストをコピーしました', 'success');
  } catch(e) {
    showToast('コピーに失敗しました', 'error');
  }
}

// =========================================================
// Word (.doc) として保存
// =========================================================
function saveAsWord() {
  const outputArea = document.getElementById('output-area');
  if (!outputArea.innerHTML.trim()) {
    showToast('保存する内容がありません', 'error');
    return;
  }

  const htmlContent = `
<html xmlns:o='urn:schemas-microsoft-com:office:office'
      xmlns:w='urn:schemas-microsoft-com:office:word'
      xmlns='http://www.w3.org/TR/REC-html40'>
<head>
<meta charset='UTF-8'>
<meta http-equiv='Content-Type' content='text/html; charset=UTF-8'>
<style>
  body {
    font-family: 'MS Mincho', 'ＭＳ 明朝', serif;
    font-size: 12pt;
    line-height: 2.0;
    margin: 2cm;
    color: #000;
  }
  ruby { ruby-align: center; }
  rt {
    font-size: 0.5em;
    font-family: 'MS PGothic', 'ＭＳ Ｐゴシック', sans-serif;
  }
</style>
</head>
<body>
${outputArea.innerHTML}
</body>
</html>`;

  const blob = new Blob([htmlContent], { type: 'application/msword;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'furigana_' + getTimestamp() + '.doc';
  a.click();
  URL.revokeObjectURL(url);
  showToast('Wordファイルをダウンロードしました', 'success');
}

function getTimestamp() {
  const d = new Date();
  return `${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}`;
}

// =========================================================
// クリア
// =========================================================
function clearInput() {
  document.getElementById('input-text').value = '';
  document.getElementById('char-count').textContent = '0 文字';
}

function clearDict() {
  document.getElementById('dict-text').value = '';
}

function clearOutput() {
  document.getElementById('output-area').innerHTML = '';
  document.getElementById('ruby-count').textContent = '';
}

// =========================================================
// トースト通知
// =========================================================
let toastTimer = null;
function showToast(msg, type = '') {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.className = 'show' + (type ? ' ' + type : '');
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => {
    toast.classList.remove('show');
  }, 3000);
}
</script>
</body>
</html>
